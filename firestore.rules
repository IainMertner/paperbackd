rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      let u = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return u.data != null && u.data.get('isAdmin', false) == true;
    }

    // User profiles — any signed-in user can read (needed to show friend names),
    // but only the owner can write their own doc.
    match /users/{uid} {
      allow read:   if request.auth != null;
      allow create: if request.auth.uid == uid;
      allow update: if request.auth.uid == uid || isAdmin()
        // Allow anyone to remove themselves from this user's following list (remove follower).
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['following'])
            && request.resource.data.following == resource.data.following.removeAll([request.auth.uid]));
      allow delete: if request.auth.uid == uid;

      // Books subcollection — any signed-in user can read (for friend book status),
      // but only the owner can write. Admins can also write.
      match /books/{bookId} {
        allow read:  if request.auth != null;
        allow write: if request.auth.uid == uid || isAdmin();
      }

      // Lists subcollection — any signed-in user can read, only the owner can write.
      match /lists/{listId} {
        allow read:  if request.auth != null;
        allow write: if request.auth.uid == uid || isAdmin();
      }
    }

    // Activity feed — readable by any signed-in user, writable only by the event owner.
    match /activity/{activityId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.uid ||
        isAdmin() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
      );
      // Also allow the target of a followed event to delete it (remove follower).
      allow delete: if request.auth != null && (request.auth.uid == resource.data.uid || request.auth.uid == resource.data.targetUid || isAdmin());
    }

    // Global config (e.g. author country overrides) — readable by any signed-in user,
    // writable only by admins.
    match /config/{docId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    // Username index — publicly readable so signup can check availability
    // before the account exists, and so add-friend lookups work.
    // Writable only at account creation, deletable only by the username owner.
    match /usernames/{username} {
      allow read:   if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        resource.data.uid == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['authEmail']);
      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/usernames/$(username)).data.uid == request.auth.uid;
    }
  }
}
